# Salesforce Connection
SF_USERNAME=operator@company.com
SF_PASSWORD=your_password_here
SF_SECURITY_TOKEN=your_security_token_here
SF_DOMAIN=login

# Customer Data Store
CUSTOMER_DATA_PATH=./data/customer_data.json

# Logging
LOG_LEVEL=INFO

# Mobius API (optional — leave empty to disable sync)
MOBIUS_API_URL=
MOBIUS_API_KEY=
MOBIUS_TIMEOUT=30

# Jira Integration (optional — leave empty to disable)
JIRA_BASE_URL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_TEST_PLAN_KEY=
